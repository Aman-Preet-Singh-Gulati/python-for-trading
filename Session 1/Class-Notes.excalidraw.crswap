      "type": "text",
      "x": 242.19424438476562,
      "y": 1835.300048828125,
      "width": 1166.731201171875,
      "height": 315,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
