      "seed": 1532049971,
      "version": 31,
      "versionNonce": 123733821,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782346109716,
      "link": null,
      "locked": false,
      "text": "• What's the real difference between delegating to an agent and delegating to a \njunior analyst — and where does that analogy break down?",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "• What's the real difference between delegating to an agent and delegating to a \njunior analyst — and where does that analogy break down?",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Ccqry4vOHYc0TghHhEoeF",
      "type": "text",
      "x": 272.9657970240468,
      "y": 7001.701804909834,
