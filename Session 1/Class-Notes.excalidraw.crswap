      "type": "text",
      "x": 214.00319550006884,
      "y": 6235.382343893453,
      "width": 900.5916748046875,
      "height": 105,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
