    {
      "id": "1mffmn4GIkJcqlI23iHKE",
      "type": "text",
      "x": 360.7541198730469,
      "y": 3927.0001335144043,
      "width": 747.2916259765625,
      "height": 140,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5H",
      "roundness": null,
      "seed": 1745966730,
      "version": 91,
      "versionNonce": 670415133,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1782286668300,
      "link": null,
      "locked": false,
      "text": "The same loop skeleton can power completely different\ntools — a question-answerer or a paragraph-writer —\njust by changing the system prompt and what we do\nwith the input.",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The same loop skeleton can power completely different tools — a question-answerer or a paragraph-writer — just by changing the system prompt and what we do with the input.",
      "autoResize": false,
      "lineHeight": 1.25
    },
