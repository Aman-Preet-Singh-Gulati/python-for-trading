    {
      "id": "-Cc4Wx6w4fJ3PzrUhIxQr",
      "type": "text",
      "x": 123.30087998770756,
      "y": 3442.7268719661797,
      "width": 719.4876708984375,
      "height": 140,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
