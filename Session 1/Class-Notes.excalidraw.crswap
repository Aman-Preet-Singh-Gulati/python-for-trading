      "type": "text",
      "x": 199.94575769465428,
      "y": 8125.70213432881,
      "width": 827.4274291992188,
      "height": 385,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
