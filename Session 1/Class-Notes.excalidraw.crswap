      "seed": 305934419,
      "version": 126,
      "versionNonce": 1248195037,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1782324017799,
      "link": null,
      "locked": false,
      "text": "CHALLENGE 1  Find the Breaking Point\nDo this:\n8.        Set TEMPERATURE = 2.0 and run the same question three times\n9.        Note what happens to grammar, coherence, and factual accuracy\n10.        Try TEMPERATURE = 0.3 — compare with 0.0\nWhat to notice:\n–        At 2.0 most models start producing incoherent or repetitive output — \n          the probability weights get so distorted that unlikely words dominate\n–        0.3 is the sweet spot many production AI tools use — slightly varied but still reliable\n–        Groq may cap temperature at 2.0 — \n          if you get an API error above that, note it: 'the API itself enforces a limit'\n",
      "fontSize": 28,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "CHALLENGE 1  Find the Breaking Point\nDo this:\n8.        Set TEMPERATURE = 2.0 and run the same question three times\n9.        Note what happens to grammar, coherence, and factual accuracy\n10.        Try TEMPERATURE = 0.3 — compare with 0.0\nWhat to notice:\n–        At 2.0 most models start producing incoherent or repetitive output — \n          the probability weights get so distorted that unlikely words dominate\n–        0.3 is the sweet spot many production AI tools use — slightly varied but still reliable\n–        Groq may cap temperature at 2.0 — \n          if you get an API error above that, note it: 'the API itself enforces a limit'\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
