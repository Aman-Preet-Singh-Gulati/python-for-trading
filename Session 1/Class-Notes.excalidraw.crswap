    {
      "id": "K88o3-VZIRplP7ZQnWvl8",
      "type": "text",
      "x": 292.1999816894531,
      "y": 3020.300090789795,
      "width": 992.4594116210938,
      "height": 350,
      "angle": 0,
      "strokeColor": "#1e1e1e",
