      "boundElements": [],
      "updated": 1782288299382,
      "link": null,
      "locked": false,
      "text": "–        At 2.0 most models start producing incoherent\nor repetitive output — the probability weights get so\ndistorted that unlikely words dominate",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "–        At 2.0 most models start producing incoherent or repetitive output — the probability weights get so distorted that unlikely words dominate",
      "autoResize": false,
      "lineHeight": 1.25
    },
