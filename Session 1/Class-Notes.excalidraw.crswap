    {
      "id": "qhsUrxcqPOv-qLbUF-PRC",
      "type": "text",
      "x": 236.2605844060961,
      "y": 2914.3393889330473,
      "width": 1259.1590576171875,
      "height": 490,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b7E",
      "roundness": null,
      "seed": 2009646259,
      "version": 345,
      "versionNonce": 1382136563,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782327527007,
      "link": null,
      "locked": false,
      "text": "PROMPT DO'S\n•        Be specific about instrument and timeframe, every single time.\n•        Give it the real numbers when precision matters — \n          it doesn't know today's live price unless you tell it.\n•        Ask it to flag its own uncertainty, especially with anything market-related.\n•        Treat the first response as a draft, and refine your prompt based on what's missing.\n\nPROMPT DON'TS\n•        Ask it to predict the future with certainty. \"Will this go up tomorrow\" is the wrong question —\n          \"what does this pattern suggest, and how confident should I be\" is the right one.\n•        Leave the instrument or timeframe ambiguous.\n•        Stack three unrelated asks into one prompt — break it into steps.\n•        Accept the first output uncritically. We'll come back to exactly why later today.\n",
      "fontSize": 28,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "PROMPT DO'S\n•        Be specific about instrument and timeframe, every single time.\n•        Give it the real numbers when precision matters — \n          it doesn't know today's live price unless you tell it.\n•        Ask it to flag its own uncertainty, especially with anything market-related.\n•        Treat the first response as a draft, and refine your prompt based on what's missing.\n\nPROMPT DON'TS\n•        Ask it to predict the future with certainty. \"Will this go up tomorrow\" is the wrong question —\n          \"what does this pattern suggest, and how confident should I be\" is the right one.\n•        Leave the instrument or timeframe ambiguous.\n•        Stack three unrelated asks into one prompt — break it into steps.\n•        Accept the first output uncritically. We'll come back to exactly why later today.\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
