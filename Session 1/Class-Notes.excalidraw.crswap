      "isDeleted": false,
      "boundElements": [],
      "updated": 1782345417444,
      "link": null,
      "locked": false,
      "text": "• \"First — Task. What do we actually want it to do?\" \n• \"Now Input — which stock, exactly, and what timeframe?\" \n• \"Now Format — how do we want it back?\" \n• \"And Constraints — what should it NOT do?\" \n",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "• \"First — Task. What do we actually want it to do?\" \n• \"Now Input — which stock, exactly, and what timeframe?\" \n• \"Now Format — how do we want it back?\" \n• \"And Constraints — what should it NOT do?\" \n",
      "autoResize": true,
      "lineHeight": 1.25
    },
