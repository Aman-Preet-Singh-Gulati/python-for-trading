    {
      "id": "CPiNXIcnMSuDs9q6CeyhE",
      "type": "text",
      "x": 1723.1684950937217,
      "y": 3915.643222771797,
      "width": 311.38787841796875,
      "height": 280,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3yV",
      "roundness": null,
      "seed": 2094832100,
      "version": 263,
      "versionNonce": 1409403094,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1781773415313,
      "link": null,
      "locked": false,
      "text": "AI predicts the next\nword based on\npatterns from billions\nof examples. It makes\nvery smart guesses —\nbut guesses aren't the\nsame as\nunderstanding.",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "LZFtpaE2WlW9aM_G1hH-u",
      "originalText": "AI predicts the next word based on patterns from billions of examples. It makes very smart guesses — but guesses aren't the same as understanding.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "3Df2A4Cv1LupjSI_AnWPe",
      "type": "text",
      "x": 286.7951354980469,
      "y": 4613.700103759766,
      "width": 1074.527587890625,
      "height": 875,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4B",
      "roundness": null,
      "seed": 1167017948,
      "version": 548,
      "versionNonce": 1014781834,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1781773415313,
      "link": null,
      "locked": false,
      "text": "1. Complete the Story\nFinish these sentences in your own words:\na) The storm was getting louder, and then suddenly...\nb) She opened the mysterious box and found...\nc) The best thing about weekends is...\n\n2. Compare Predictions\nAsk 3 different people (classmates, family) to complete the same sentence: \n“After school, I always feel...” \nWrite down all the answers. \nAre they similar or different? What does this tell you about predictions?\n\n3. AI vs. You\nThink of a question where you think AI would guess the same as you, \nand one where you think your answer would be more creative. Write both down.\n\n\n\n\n\n⭐ Bonus Challenge\nWrite a short paragraph (4–5 sentences) predicting what you think AI \nwill be able to do in 10 years. Remember: base it on what you know about\npatterns and learning!\n",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Complete the Story\nFinish these sentences in your own words:\na) The storm was getting louder, and then suddenly...\nb) She opened the mysterious box and found...\nc) The best thing about weekends is...\n\n2. Compare Predictions\nAsk 3 different people (classmates, family) to complete the same sentence: \n“After school, I always feel...” \nWrite down all the answers. \nAre they similar or different? What does this tell you about predictions?\n\n3. AI vs. You\nThink of a question where you think AI would guess the same as you, \nand one where you think your answer would be more creative. Write both down.\n\n\n\n\n\n⭐ Bonus Challenge\nWrite a short paragraph (4–5 sentences) predicting what you think AI \nwill be able to do in 10 years. Remember: base it on what you know about\npatterns and learning!\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
