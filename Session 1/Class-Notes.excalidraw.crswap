      "versionNonce": 981216861,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782346550834,
      "link": null,
      "locked": false,
      "text": "Context: I'm extending the same project into a Streamlit\ndashboard.\nTask: Build an app that visualizes recent price history for a\nstock.\nInput: Fetch 6 months of daily OHLC data for RELIANCE.NS using\nyfinance.\nFormat: Plot the closing price as a line chart, with date on the\nx-axis, price on the y-axis, and a clear chart title.\nConstraint: Keep it to a single page app — no extra navigation or\ntabs yet.\n",
      "fontSize": 28,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Context: I'm extending the same project into a Streamlit\ndashboard.\nTask: Build an app that visualizes recent price history for a\nstock.\nInput: Fetch 6 months of daily OHLC data for RELIANCE.NS using\nyfinance.\nFormat: Plot the closing price as a line chart, with date on the\nx-axis, price on the y-axis, and a clear chart title.\nConstraint: Keep it to a single page app — no extra navigation or\ntabs yet.\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "gcX78mOQn5o8MqnSq4Pgx",
      "type": "text",
      "x": 121.26381190132093,
      "y": 8661.442382101812,
      "width": 911.34375,
      "height": 70,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
