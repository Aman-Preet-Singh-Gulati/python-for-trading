      "isDeleted": false,
      "boundElements": [],
      "updated": 1782347130859,
      "link": null,
      "locked": false,
      "text": "• Going from numbers to language, what gets added that wasn't in the raw data\n — and is that addition always a good thing?",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "• Going from numbers to language, what gets added that wasn't in the raw data\n — and is that addition always a good thing?",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "rXm0jtMsumPoYEYTd5v80",
      "type": "text",
      "x": -127.08230962585182,
      "y": 11403.5970047505,
      "width": 1221.9476318359375,
      "height": 70,
      "angle": 0,
