      "isDeleted": false,
      "boundElements": [],
      "updated": 1782347334139,
      "link": null,
      "locked": false,
      "text": "• If AI sounds equally confident whether it's right or wrong, \nwhat's actually a reliable signal that you should double-check it?",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "• If AI sounds equally confident whether it's right or wrong, \nwhat's actually a reliable signal that you should double-check it?",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "1CiTILOB19FacV1DMpUd6",
      "type": "text",
      "x": -40.98112496220989,
      "y": 12078.15326292172,
      "width": 975.295654296875,
      "height": 105,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
