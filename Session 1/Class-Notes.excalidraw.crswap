    {
      "id": "trI-nnqUtfVwruzlL38e6",
      "type": "text",
      "x": -19.895161897891512,
      "y": 12609.988821195664,
      "width": 850.9754638671875,
      "height": 385,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
