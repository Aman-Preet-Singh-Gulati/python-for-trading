    {
      "id": "a-Yl9OIdTCBR8qiT_g3k1",
      "type": "text",
      "x": 373.80609130859375,
      "y": 3626.100109100342,
      "width": 724.3876953125,
      "height": 105,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5E",
      "roundness": null,
      "seed": 269676822,
      "version": 90,
      "versionNonce": 1465243837,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1782286668300,
      "link": null,
      "locked": false,
      "text": "A loop repeats the same block of instructions until a\ncondition tells it to stop. This is how every chat\ninterface stays open and ready.",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A loop repeats the same block of instructions until a condition tells it to stop. This is how every chat interface stays open and ready.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "kd71c1dxD9ivq40gUPeYd",
      "type": "text",
      "x": 441.5999450683594,
      "y": 3850.7000846862793,
      "width": 1784.074951171875,
      "height": 35,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5F",
      "roundness": null,
      "seed": 511228106,
      "version": 25,
      "versionNonce": 599513930,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1781807021868,
      "link": null,
      "locked": false,
      "text": "Conditions are decision points — 'has the exit word been typed?' is exactly the same logic as 'should this AI refuse this request?'",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Conditions are decision points — 'has the exit word been typed?' is exactly the same logic as 'should this AI refuse this request?'",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "evalEDvaAMlpIl9nvOlnw",
