      "type": "text",
      "x": 309.08532651249595,
      "y": 5200.021310805343,
      "width": 954.4357299804688,
      "height": 105,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
