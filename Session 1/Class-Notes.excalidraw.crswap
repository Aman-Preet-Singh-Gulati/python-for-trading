    {
      "id": "5n1gT6TFWFd3VrQT4dmb2",
      "type": "text",
      "x": 299.1280579011915,
      "y": 5585.230984401654,
      "width": 864.6674194335938,
      "height": 385,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b7X",
      "roundness": null,
      "seed": 913901789,
      "version": 54,
      "versionNonce": 1920910717,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782345813363,
      "link": null,
      "locked": false,
      "text": "Context: I'm building a simple market data tool in Python for a\ntrading dashboard.\nTask: Write a script that pulls recent stock price data and\ndisplays it clearly.\nInput: Use the yfinance library to fetch the last 5 days of daily\nOHLC data for RELIANCE.NS.\nFormat: Print the result as a clean table with columns for date,\nopen, high, low, and close.\nConstraint: Keep the code simple and readable — no extra functions,\njust a script I can read top to bottom.\n",
      "fontSize": 28,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Context: I'm building a simple market data tool in Python for a\ntrading dashboard.\nTask: Write a script that pulls recent stock price data and\ndisplays it clearly.\nInput: Use the yfinance library to fetch the last 5 days of daily\nOHLC data for RELIANCE.NS.\nFormat: Print the result as a clean table with columns for date,\nopen, high, low, and close.\nConstraint: Keep the code simple and readable — no extra functions,\njust a script I can read top to bottom.\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
