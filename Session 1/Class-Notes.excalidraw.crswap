      "type": "text",
      "x": 152.50240038264616,
      "y": 6517.700231909169,
      "width": 1037.11962890625,
      "height": 70,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b7c",
      "roundness": null,
      "seed": 2010326099,
      "version": 49,
      "versionNonce": 961550813,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782346051320,
      "link": null,
      "locked": false,
      "text": "• This printed a table you didn't write the code for. \nWhat's one risk of trusting AI-generated code you haven't read line by line?",
