      "isDeleted": false,
      "boundElements": [],
      "updated": 1782347356448,
      "link": null,
      "locked": false,
      "text": "• Is 'AI drafts, you verify' a habit that scales? \nWhat happens to that rule when you're checking ten dashboards a day \ninstead of one?",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
