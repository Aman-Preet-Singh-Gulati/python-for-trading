      "isDeleted": true,
      "boundElements": [],
      "updated": 1782327441224,
      "link": null,
      "locked": false,
      "text": "•        Ask it to predict the future with certainty.\n\"Will this go up tomorrow\" is the wrong question —\n\"what does this pattern suggest, and how confident\nshould I be\" is the right one.",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "•        Ask it to predict the future with certainty. \"Will this go up tomorrow\" is the wrong question — \"what does this pattern suggest, and how confident should I be\" is the right one.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
