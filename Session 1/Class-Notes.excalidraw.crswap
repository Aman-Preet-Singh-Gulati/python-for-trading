      "seed": 363600339,
      "version": 38,
      "versionNonce": 1691183411,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782347448700,
      "link": null,
      "locked": false,
      "text": "Context: I want the dashboard to help interpret the data, not\njust display it — like a junior analyst summarizing a chart\nfor me.\nTask: Add an AI-generated commentary section below the chart.\nInput: Send the last 10 days of OHLC price data for the selected\nticker to the Groq API.\nFormat: A 3-sentence plain-English summary of the recent trend —\nno more, no less.\nConstraint: Only describe the trend, never a buy or sell\nrecommendation, and flag it if uncertain about the direction.\n",
      "fontSize": 28,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Context: I want the dashboard to help interpret the data, not\njust display it — like a junior analyst summarizing a chart\nfor me.\nTask: Add an AI-generated commentary section below the chart.\nInput: Send the last 10 days of OHLC price data for the selected\nticker to the Groq API.\nFormat: A 3-sentence plain-English summary of the recent trend —\nno more, no less.\nConstraint: Only describe the trend, never a buy or sell\nrecommendation, and flag it if uncertain about the direction.\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "3BTzSRB5BDjUR6P0dVv1T",
      "type": "text",
      "x": -52.10989389360998,
      "y": 13180.286667543485,
      "width": 787.3877563476562,
      "height": 105,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b8H",
      "roundness": null,
      "seed": 1077000115,
      "version": 78,
      "versionNonce": 873823165,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782347633633,
      "link": null,
      "locked": false,
      "text": "• We told it not to give buy/sell recommendations — \nif it did anyway, is that a prompting mistake or a deeper \ntrust problem with the tool?",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "• We told it not to give buy/sell recommendations — \nif it did anyway, is that a prompting mistake or a deeper \ntrust problem with the tool?",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "3LVfhzZl91xn3F-z6O1mp",
      "type": "text",
      "x": -81.59112017721321,
      "y": 13352.68418513699,
      "width": 972.1036987304688,
      "height": 105,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
