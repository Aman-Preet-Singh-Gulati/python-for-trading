      "index": "b8I",
      "roundness": null,
      "seed": 989634483,
      "version": 93,
      "versionNonce": 682165053,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782347630229,
      "link": null,
      "locked": false,
      "text": "• This summary only saw 10 days of data. \nWhat might it confidently say that someone who's watched this stock \nfor months would immediately disagree with?",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "• This summary only saw 10 days of data. \nWhat might it confidently say that someone who's watched this stock \nfor months would immediately disagree with?",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "YTFFsyJXz36xTBGGrha0m",
