      "isDeleted": true,
      "boundElements": [],
      "updated": 1782286668300,
      "link": null,
      "locked": false,
      "text": "Conditions are decision points — 'has the exit word\nbeen typed?' is exactly the same logic as 'should this\nAI refuse this request?'",
